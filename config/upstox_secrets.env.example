# Template only - DO NOT put real values in this file (it IS committed to git).
# On the VM, copy this to config/upstox_secrets.env (gitignored) and fill it in,
# or just run oracle/setup_trading_secrets.sh which writes it for you with
# chmod 600 and without ever echoing values to the terminal history.
#
# UPSTOX_USERNAME=9999999999
# UPSTOX_PASSWORD=your-login-password
# UPSTOX_PIN_CODE=123456
# UPSTOX_TOTP_SECRET=BASE32SECRETFROMAUTHENTICATORSETUP
# UPSTOX_CLIENT_ID=your-api-key
# UPSTOX_CLIENT_SECRET=your-api-secret
# UPSTOX_REDIRECT_URI=https://your-registered-redirect-uri
